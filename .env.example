# Environment variables for PII NER project

# Device configuration
DEVICE=cuda
# DEVICE=cpu  # Uncomment for CPU-only

# Data paths (relative to project root)
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
ANSWER_DIR=./data/answer
MODEL_DIR=./models
LOG_DIR=./logs

# Model configuration
MODEL_NAME=DeepPavlov/rubert-base-cased
MODEL_CHECKPOINT=models/ner_checkpoint
TOKENIZER_NAME=DeepPavlov/rubert-base-cased

# Training configuration
TRAIN_EPOCHS=10
TRAIN_BATCH_SIZE=32
EVAL_BATCH_SIZE=64
LEARNING_RATE=2e-5
WARMUP_STEPS=500
GRADIENT_ACCUMULATION_STEPS=1
MAX_GRAD_NORM=1.0

# Inference configuration
INFERENCE_BATCH_SIZE=64
INFERENCE_THRESHOLD=0.5

# Regex settings
REGEX_MAX_LENGTH=100
REGEX_TIMEOUT=30

# Merge settings
MERGE_STRATEGY=regex_priority
ALLOW_OVERLAPS=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FORMAT=text  # Uncomment for human-readable logs

# Random seed (for reproducibility)
RANDOM_SEED=42

# Performance
NUM_WORKERS=4
PIN_MEMORY=true

# Debugging
DEBUG=false
VERBOSE=false